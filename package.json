{
  "name": "harvard-data-migration",
  "version": "1.0.0",
  "description": "Clean-room TypeScript engine to migrate DVC content-addressed data between S3 remotes with hardened validate-before-delete.",
  "private": true,
  "type": "module",
  "keywords": ["dvc", "s3", "migration", "data-engineering"],
  "author": "",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  },
  "bin": {
    "dvcm": "./dist/src/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "dvcm": "tsx src/cli/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "commander": "^12.1.0",
    "p-limit": "^6.1.0",
    "pino": "^9.5.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testcontainers/localstack": "^12.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
